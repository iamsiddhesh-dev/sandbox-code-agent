# API Keys
GROQ_API_KEY=gsk_...
E2B_API_KEY=...

# Sandbox backend selection: "e2b" or "docker"
SANDBOX_BACKEND=e2b

# Runtime code-gen model (Groq-hosted)
CODEGEN_MODEL=llama-3.3-70b-versatile

# ---------------------------------------------------------------------------
# Public demo (optional). Leave PUBLIC_DEMO unset for local use — everything
# below is ignored and the app keeps its local defaults.
#
# With PUBLIC_DEMO=1 the app refuses to start unless DEMO_PASSPHRASE is set and
# SANDBOX_BACKEND=e2b (free hosts have no Docker daemon).
# ---------------------------------------------------------------------------
# PUBLIC_DEMO=1
# DEMO_PASSPHRASE=change-me

# Global kill switch: once the day's spend reaches this, runs stop for everyone.
# DAILY_SPEND_CAP_USD=1.00

# Per-session sliding window.
# HOSTED_RATE_LIMIT_RUNS=5
# HOSTED_RATE_LIMIT_WINDOW_S=300

# Per-request ceilings, deliberately tighter than the local defaults.
# HOSTED_MAX_ATTEMPTS=2
# HOSTED_MAX_TOTAL_TOKENS=8000
# HOSTED_MAX_COST_USD=0.006
# HOSTED_MAX_SANDBOX_SECONDS=40
# HOSTED_PER_RUN_TIMEOUT_S=20

# Where the spend ledger and rate-limit state live.
# HOSTED_STATE_PATH=.hosted_state/limits.db
